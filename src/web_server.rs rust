    ]);
    const bd=await br.json();
    const ed=await er.json();
    const labels=bd.prices.map(p=>new Date(p[0]).toLocaleDateString('fr-FR',{{month:'short',day:'numeric'}}));
    new Chart(document.getElementById('priceChart'),{{
      type:'line',
      data:{{
        labels,
        datasets:[
          {{label:'BTC ($)',data:bd.prices.map(p=>p[1]),borderColor:'#f59e0b',backgroundColor:'rgba(245,158,11,.08)',yAxisID:'y',tension:.4,fill:true,pointRadius:3}},
          {{label:'ETH ($)',data:ed.prices.map(p=>p[1]),borderColor:'#60a5fa',backgroundColor:'rgba(96,165,250,.08)',yAxisID:'y1',tension:.4,fill:true,pointRadius:3}},
        ]
      }},
      options:{{
        responsive:true,
        interaction:{{mode:'index',intersect:false}},
        plugins:{{legend:{{labels:{{color:'#94a3b8',font:{{size:11}}}}}}}},
        scales:{{
          x:{{ticks:{{color:'#475569',font:{{size:10}}}},grid:{{color:'#1e1e4a'}}}},
          y:{{type:'linear',position:'left',ticks:{{color:'#f59e0b',font:{{size:10}},callback:v=>'$'+v.toLocaleString()}},grid:{{color:'#1e1e4a'}}}},
          y1:{{type:'linear',position:'right',ticks:{{color:'#60a5fa',font:{{size:10}},callback:v=>'$'+v.toLocaleString()}},grid:{{drawOnChartArea:false}}}},
        }}
      }}
    }});
