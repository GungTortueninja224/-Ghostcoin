async function fetchPrices(){{
  try{{
    const r=await fetch('https://api.coingecko.com/api/v3/simple/price?ids=bitcoin,ethereum,binancecoin&vs_currencies=usd&include_24hr_change=true');
    const d=await r.json();
    const fmt=(n)=>n>=1000?'$'+n.toLocaleString('en-US',{{maximumFractionDigits:0}}):'$'+n.toFixed(2);
    const chg=(v,id,cid)=>{{
      document.getElementById(id).textContent=fmt(v.usd);
      const c=v.usd_24h_change.toFixed(2);
      const el=document.getElementById(cid);
      el.textContent=(c>0?'+':'')+c+'%';
      el.className='tick-chg '+(c>0?'up':'dn');
    }};
    chg(d.bitcoin,'btcP','btcC');
    chg(d.ethereum,'ethP','ethC');
    chg(d.binancecoin,'bnbP','bnbC');
    document.getElementById('upd').textContent=new Date().toLocaleTimeString();
    return d;
  }}catch(e){{console.warn('price err',e);}}
}}

